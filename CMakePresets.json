{
	"version": 3,
	"configurePresets": [
		{
			"name": "dev",
			"displayName": "Development",
			"generator": "Ninja",
			"binaryDir": "build/dev",
			"cacheVariables": {
				"CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
				"BUILD_TESTS": "ON"
			}
		},

		{
			"name": "rel",
			"displayName": "Release",
			"generator": "Ninja",
			"binaryDir": "build/rel",
			"cacheVariables": {
				"CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
				"CMAKE_BUILD_TYPE": "Release",
				"BUILD_TESTS": "OFF"
			}
		}
	],

	"buildPresets": [
		{
			"name": "dev",
			"configurePreset": "dev"
		},
		{
			"name": "rel",
			"configurePreset": "rel"
		}
	]
}
